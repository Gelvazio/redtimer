# Raiz do Redmine (sem barra no fim). Ex.: https://redmine.suaempresa.com ou https://host/redmine
VITE_REDMINE_URL=https://redmine.exemplo.com
VITE_REDMINE_API_KEY=

# Opcional: força (true) ou desliga (false) o proxy /api/redmine. Em *.vercel.app o proxy liga sozinho.
# Domínio próprio na Vercel: use true aqui e no painel da Vercel (Build).
# VITE_USE_SERVER_PROXY=true

# Só no servidor da Vercel (não é VITE_*): hostnames permitidos pelo proxy (separados por vírgula).
# Se vazio, qualquer host HTTPS informado em "URL do Redmine" é aceito (menos restritivo).
REDMINE_ALLOWED_HOSTS=redmine.exemplo.com
